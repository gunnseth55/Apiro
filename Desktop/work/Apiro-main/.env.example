# =============================================================================
# Apiro — Environment Configuration Template
# =============================================================================
# Copy this file to .env and edit the values for your environment.
# .env is git-ignored and never committed.
#
# For Docker Compose: values here are loaded automatically.
# For local dev:      install python-dotenv and call load_dotenv() OR
#                     export variables manually in your shell.
# =============================================================================

# ---------------------------------------------------------------------------
# LLM / Ollama
# ---------------------------------------------------------------------------
# URL of the Ollama server.
#   Local:  http://localhost:11434   (default)
#   Docker: http://ollama:11434      (set automatically by docker-compose)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model tag to use for graph traversal and entropy computation.
# Must be pulled on the Ollama server before use.
# Good options: mistral:latest, llama3.1:8b, llama2:latest, phi3:mini
PRIMARY_MODEL=mistral:latest

# ---------------------------------------------------------------------------
# Embedding / ChromaDB
# ---------------------------------------------------------------------------
# Sentence-transformer model for RAG embeddings (768-dim).
EMBED_MODEL=all-mpnet-base-v2

# ChromaDB collection name.
CHROMA_COLLECTION=apiro_corpus

# Number of RAG chunks retrieved per query.
RAG_TOP_K=6

# ---------------------------------------------------------------------------
# Graph traversal tuning
# ---------------------------------------------------------------------------
# Maximum depth the belief graph will explore.
MAX_TRAVERSAL_DEPTH=8

# Hard cap on total nodes expanded per traversal run.
MAX_NODES_PER_RUN=30

# Child hypotheses generated per node expansion (keep at 3 for best results).
N_CHILD_HYPOTHESES=3

# ---------------------------------------------------------------------------
# Paths (override for custom storage locations)
# ---------------------------------------------------------------------------
# DATA_DIR=data
# CHROMA_DIR=data/chroma_db
# LOG_DIR=data/logs

# ---------------------------------------------------------------------------
# Web server
# ---------------------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000

# ---------------------------------------------------------------------------
# API keys (optional)
# ---------------------------------------------------------------------------
# HuggingFace token — increases rate limits for model downloads (optional).
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# OMIM API key — required only if using OMIM corpus source.
# OMIM_API_KEY=your_omim_key_here
